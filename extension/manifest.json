{
  "manifest_version": 3,
  "name": "AI Security Assistant",
  "version": "1.0",
  "description": "Automatically checks pages and links for phishing indicators.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["config/constants.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
